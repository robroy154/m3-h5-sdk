{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "tsc: watch",
            "type": "shell",
            "command": "tsc",
            "args": ["-p", ".", "--watch"],
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "tsc: build",
            "type": "shell",
            "command": "tsc",
            "args": ["-p", "."],
            "problemMatcher": "$tsc",
            "group": "build"
        }
    ]
}
